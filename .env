# API 配置
DASHSCOPE_API_KEY=xxxxxxxxx
OPENAI_API_BASE=xxxxxxxx
OPENAI_API_KEY=${DASHSCOPE_API_KEY}

# 模型配置
EMBEDDING_MODEL_NAME=BAAI/bge-large-zh-v1.5
RERANKER_MODEL_NAME=BAAI/bge-reranker-large-zh-v1.5
LLM_MODEL_NAME=qwen-max
MULTIMODAL_MODEL_NAME=qwen-vl-max
MULTIMODAL_EMBEDDING_MODEL_TYPE=open_clip
MULTIMODAL_EMBEDDING_MODEL_NAME=laion/CLIP-ViT-H-14-laion2B-s32B-b79K
MULTIMODAL_EMBEDDING_DIM=1024
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# Milvus 配置
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=rag_full_integration
MILVUS_DIM=1024
MILVUS_INDEX_TYPE=HNSW
MILVUS_METRIC_TYPE=IP
MILVUS_HNSW_M=16
MILVUS_HNSW_EF_CONSTRUCTION=200
MILVUS_HNSW_EF_SEARCH=128

# 检索配置
COARSE_TOP_K_PER_PATH=30
RERANK_TOP_N=8
MAX_REACT_ITERATIONS=3
MAX_DOCS_IN_CONTEXT=6

# 文档处理配置
CHUNK_SIZE=512
CHUNK_OVERLAP=64
PARENT_CHUNK_SIZE=2048
PARENT_CHUNK_OVERLAP=256
CHILD_CHUNK_SIZE=384
CHILD_CHUNK_OVERLAP=64
OCR_LANG=ch

# 记忆管理配置
MEMORY_MAX_TOKENS=8000
MEMORY_SUMMARY_THRESHOLD=6000
MEMORY_LONG_TERM_THRESHOLD=10